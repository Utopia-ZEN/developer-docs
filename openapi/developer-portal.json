          {
            "type": "object",
            "required": [
              "wallet_addresses",
              "localisations",
              "mini_app_path",
              "app_id"
            ],
            "properties": {
              "wallet_addresses": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Array of wallet addresses to notify. Users must have opted in. Max 1000 per call."
              },
              "localisations": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/components/schemas/SendNotificationLocalisation"
                },
